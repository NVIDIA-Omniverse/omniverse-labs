over "Flattened_Prototype_1"
{
    def Shader "Principled_BSDF" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "UsdPreviewSurface"
        float inputs:clearcoat = 0
        float inputs:clearcoatRoughness = 0.03
        color3f inputs:diffuseColor.connect = </Flattened_Prototype_1/Albedo.outputs:rgb>
        float inputs:ior = 1.5
        float inputs:metallic.connect = </Flattened_Prototype_1/ORM.outputs:b>
        normal3f inputs:normal.connect = </Flattened_Prototype_1/Normal.outputs:rgb>
        float inputs:opacity = 1
        float inputs:roughness.connect = </Flattened_Prototype_1/ORM.outputs:g>
        float inputs:specular = 0.5
        token outputs:surface
    }

    def Shader "Albedo" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "UsdUVTexture"
        asset inputs:file = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_albedo_1.png@
        token inputs:sourceColorSpace = "sRGB"
        float2 inputs:st.connect = </Flattened_Prototype_1/Mapping.outputs:result>
        token inputs:wrapS = "repeat"
        token inputs:wrapT = "repeat"
        float3 outputs:rgb
    }

    def Shader "Mapping" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "UsdTransform2d"
        float2 inputs:in.connect = </Flattened_Prototype_1/uvmap.outputs:result>
        float inputs:rotation = 0
        float2 inputs:scale = (1, 1)
        float2 inputs:translation = (0, 0)
        float2 outputs:result
    }

    def Shader "uvmap" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "UsdPrimvarReader_float2"
        string inputs:varname = "st"
        float2 outputs:result
    }

    def Shader "ORM" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "UsdUVTexture"
        asset inputs:file = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_orm_1.png@
        token inputs:sourceColorSpace = "raw"
        float2 inputs:st.connect = </Flattened_Prototype_1/Mapping.outputs:result>
        token inputs:wrapS = "repeat"
        token inputs:wrapT = "repeat"
        float outputs:b
        float outputs:g
    }

    def Shader "Normal" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "UsdUVTexture"
        float4 inputs:bias = (-1, -1, -1, -1)
        asset inputs:file = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_normal_1.png@
        float4 inputs:scale = (2, 2, 2, 2)
        token inputs:sourceColorSpace = "raw"
        float2 inputs:st.connect = </Flattened_Prototype_1/Mapping.outputs:result>
        token inputs:wrapS = "repeat"
        token inputs:wrapT = "repeat"
        float3 outputs:rgb
    }

    def Shader "OmniPBR_Shader" (
        apiSchemas = ["NodeDefAPI"]
    )
    {
        uniform token info:id = "mdl:OmniPBR"
        uniform token info:implementationSource = "sourceAsset"
        asset info:mdl:sourceAsset = @OmniPBR.mdl@
        token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
        float inputs:bump_factor = 0.1
        asset inputs:diffuse_texture = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_albedo_1.png@ (
            colorSpace = "sRGB"
        )
        color3f inputs:emissive_color = (1, 1, 1)
        float inputs:emissive_intensity = 0
        asset inputs:metallic_texture = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_orm_1.png@ (
            colorSpace = "raw"
        )
        asset inputs:normalmap_texture = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_normal_1.png@ (
            colorSpace = "raw"
        )
        float inputs:opacity_constant = 1
        asset inputs:reflectionroughness_texture = @./omniverse-content-production.s3-us-west-2../aws.com/Assets/Isaac/6.0/Isaac/SimReady/Industrial/Warehouse/Boxes/Cardboard_Box_A02/textures/t_cardbox_a2_orm_1.png@ (
            colorSpace = "raw"
        )
        float inputs:specular_level = 0.5
        token outputs:out
    }
