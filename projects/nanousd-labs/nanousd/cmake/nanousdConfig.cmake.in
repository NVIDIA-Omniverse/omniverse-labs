@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/nanousdTargets.cmake")

# Exported targets:
#   nanousd::nanousd — shared library (core implementation + built-in backend)
#   nanousd::nanousdapi — C API dispatch (static or shared depending on build)
#
# Typical usage:
#   find_package(nanousd REQUIRED)
#   target_link_libraries(myapp PRIVATE nanousd::nanousdapi)
#
# At runtime, nanousdapi dlopen's the nanousd backend from the same directory.
# Override with NANOUSD_BACKEND=/path/to/alternative_backend.so

check_required_components(nanousd)
