#usda 1.0
(
    defaultPrim = "Geo"
)

# Jump discontinuity in `times` (§12.3.4.8). Two knots share
# stageTime=10: the pre-jump knot maps 10→10, the post-jump knot
# maps 10→0. Right-continuous evaluation wins — at exactly
# stageTime=10 the post-jump clipTime (0) is used, so radius
# reads clip_a's sample at clipTime 0.

def Scope "Geo" (
    clips = {
        dictionary default = {
            string primPath = "/Geo"
            asset[] assetPaths = [@./clip_a.usda@]
            double2[] active = [(0, 0)]
            double2[] times  = [(0, 0), (10, 10), (10, 0), (20, 10)]
        }
    }
)
{
    float radius
}
