#usda 1.0
(
    '''
    Ported from OpenUSD PCP test fixture
    testPcpMuseum_BasicNestedVariants.testenv/BasicNestedVariants/root.usda
    (Pixar OpenUSD release branch).

    Exercises simple nesting of variant sets within one file. Originally
    tracking OpenUSD bug 63723.

    Adaptation from upstream: every `add variantSets = ...` in the
    original has been rewritten to `append variantSets = ...`. `add` is
    the deprecated pre-standardization spelling of `append`; nanousd
    ingests only the current spec form.
    '''
)

def StdAvarsModel "Foo" (
    append variantSets = "which"
    variants = {
        string which = "A"
    }
)
{
    variantSet "which" = {
        "A" {
            def GprimPivot "A"
            {
                def GprimPivot "Number" (
                    append variantSets = "count"
                    variants = {
                        string count = "one"
                    }
                )
                {
                    variantSet "count" = {
                        "one" {
                            def GprimPivot "one"
                            {
                            }

                        }
                        "two" {
                            def GprimPivot "two"
                            {
                            }
                        }
                    }
                }
            }
        }
        "B" {
            def GprimPivot "B"
            {
            }
        }
    }
}

def Scope "DirectlyNestedVariants" (
    append variantSets = ['standin']
    variants = {
        string shadingVariant = "spooky"
        string standin = "anim"
    }
)
{
    variantSet "standin" = {
        "anim" (
            append variantSets = ['shadingVariant']
        ) {
            variantSet "shadingVariant" = {
                "default" {
                    def Cone "anim_default_cone"
                    {
                    }
                }
                "spooky" (
                    append variantSets = ['standin']
                ) {
                    def Sphere "anim_spooky_sphere"
                    {
                    }
                    variantSet "standin" = {
                        "anim" {
                            def Sphere "anim_spooky_anim_sphere"
                            {
                            }
                        }
                    }
                }
            }
        }
        "render" (
            append variantSets = ['shadingVariant']
        ) {
            variantSet "shadingVariant" = {
                "default" {
                    def Cube "render_default_cube"
                    {
                    }
                }
                "spooky" {
                    def Cylinder "render_spooky_cylinder"
                    {
                    }
                }
            }
        }
    }
}
