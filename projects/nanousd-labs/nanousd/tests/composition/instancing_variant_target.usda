#usda 1.0
(
    defaultPrim = "Template"
)

# Shared instancing target with a variant set. /InstanceHigh and
# /InstanceLow in instancing_variant_root.usda reference this asset
# with instanceable=true and select different variants — per spec §11.3
# the composed bodies differ, so the instances must not share a
# prototype.

def Xform "Template" (
    variantSets = "lod"
    variants = {
        string lod = "high"
    }
)
{
    int baseline = 1

    variantSet "lod" = {
        "high" {
            int fromVariant = 100

            def Scope "HighChild"
            {
                int value = 7
            }
        }
        "low" {
            int fromVariant = 10
        }
    }
}
