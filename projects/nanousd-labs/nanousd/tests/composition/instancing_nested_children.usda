#usda 1.0
(
    defaultPrim = "Assets"
)

# Three instanceable prims, each authored at a DIFFERENT path in this layer,
# each referencing the same shared template.  When this layer is in turn
# referenced by a parent stage, the parent's instancing logic must key each
# instance on its own composition arc (the reference to instancing_ref),
# not on the per-instance local opinion that happens to name it uniquely.

def Xform "Assets"
{
    def Mesh "Cone_01" (
        instanceable = true
        prepend references = @./instancing_ref.usda@</Template>
    )
    {
    }

    def Mesh "Cone_02" (
        instanceable = true
        prepend references = @./instancing_ref.usda@</Template>
    )
    {
    }

    def Mesh "Cone_03" (
        instanceable = true
        prepend references = @./instancing_ref.usda@</Template>
    )
    {
    }
}
