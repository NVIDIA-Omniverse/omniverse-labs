#usda 1.0
(
    defaultPrim = "Model"
    subLayers = [
        @./dict_resolution_base.usda@
    ]
)

# Stronger opinion via the sublayer stack. Exercises spec §12.2.5 —
# dictionary-typed metadata combines across opinions per §6.6.2.1:
#   * `fromRoot` — key only in the root layer (rule 4: kept)
#   * `fromBase` — key only in the base layer (rule 4: kept)
#   * `sharedScalar` — scalar in both; root wins (rule 2)
#   * `nested` — both values are dictionaries; recursive combine (rule 3):
#       - `rootOnly`     → from root
#       - `baseOnly`     → from base
#       - `sharedInNested` → root wins

over "Model" (
    customData = {
        bool fromRoot = true
        int sharedScalar = 999
        dictionary nested = {
            string rootOnly = "root"
            int sharedInNested = 42
        }
    }
)
{
}
