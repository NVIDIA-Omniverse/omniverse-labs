#usda 1.0

# All prim metadata fields

def Xform "AllMetadata" (
    doc = "Documentation string"
    kind = "component"
    active = true
    hidden = false
    instanceable = true
    displayName = "Display Name"
    customData = {
        string author = "test"
        int priority = 1
        dictionary extra = {
            bool debug = false
        }
    }
    assetInfo = {
        string name = "testAsset"
        string version = "1.0"
    }
)
{
}

def Mesh "InactiveHidden" (
    active = false
    hidden = true
)
{
}

def Scope "KindVariations" (
    kind = "assembly"
)
{
    def Scope "SubComponent" (
        kind = "subcomponent"
    )
    {
    }

    def Scope "Group" (
        kind = "group"
    )
    {
    }

    def Scope "Model" (
        kind = "model"
    )
    {
    }
}

# Prim metadata with standalone string as doc
def Scope "DocAsString" (
    """This documentation is a standalone string
in the metadata block."""
    kind = "component"
)
{
}
