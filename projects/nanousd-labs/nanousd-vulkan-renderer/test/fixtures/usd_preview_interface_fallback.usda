#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Z"
)

def Xform "World"
{
    def Mesh "Leaf" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        int[] faceVertexCounts = [3]
        int[] faceVertexIndices = [0, 1, 2]
        point3f[] points = [(-1, 0, 0), (1, 0, 0), (0, 1, 0)]
        rel material:binding = </World/Looks/LeafMat>
    }

    def Scope "Looks"
    {
        def Material "LeafMat"
        {
            float inputs:alpha = 0.77
            color3f inputs:baseColor = (0.12, 0.45, 0.20)
            float inputs:clearcoat = 0.20
            float inputs:clearcoatGloss = 0.75
            float inputs:ior = 1.31
            float inputs:metallic = 0.09
            float inputs:roughness = 0.83
            asset inputs:surfaceMap = @missing.ptx@

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Looks/LeafMat/HwPtexTexture_1.outputs:color>
                token outputs:surface
            }

            def Shader "HwPtexTexture_1"
            {
                uniform token info:id = "HwPtexTexture_1"
                asset inputs:file.connect = </World/Looks/LeafMat.inputs:surfaceMap>
                color3f outputs:color
            }
        }
    }
}
