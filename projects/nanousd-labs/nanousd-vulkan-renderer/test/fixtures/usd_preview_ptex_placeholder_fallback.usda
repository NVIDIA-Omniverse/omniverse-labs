#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Z"
)

def Xform "World"
{
    def Scope "Looks"
    {
        def Material "TrunkMat"
        {
            color3f inputs:baseColor = (1, 0, 0)
            asset inputs:surfaceMap = @textures/trunk_geo.ptx@

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Looks/TrunkMat/HwPtexTexture_1.outputs:color>
                token outputs:surface
            }

            def Shader "HwPtexTexture_1"
            {
                uniform token info:id = "HwPtexTexture_1"
                asset inputs:file.connect = </World/Looks/TrunkMat.inputs:surfaceMap>
                color3f outputs:color
            }
        }

        def Material "FrondMat"
        {
            asset inputs:surfaceMap = @textures/frond_geo.ptx@

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Looks/FrondMat/HwPtexTexture_1.outputs:color>
                token outputs:surface
            }

            def Shader "HwPtexTexture_1"
            {
                uniform token info:id = "HwPtexTexture_1"
                asset inputs:file.connect = </World/Looks/FrondMat.inputs:surfaceMap>
                color3f outputs:color
            }
        }
    }
}
