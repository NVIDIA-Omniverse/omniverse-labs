#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
)

def Xform "World"
{
    def PointInstancer "PI"
    {
        point3f[] positions = [(-4, 0, 0), (0, 0, 0), (4, 0, 0)]
        int[] protoIndices = [0, 0, 0]
        quatf[] orientations = [(1,0,0,0), (1,0,0,0), (1,0,0,0)]
        float3[] scales = [(1,1,1), (1,1,1), (1,1,1)]
        rel prototypes = [</World/PI/Prototypes/Cube>]

        def Scope "Prototypes"
        {
            def Mesh "Cube"
            {
                int[] faceVertexCounts = [3, 3]
                int[] faceVertexIndices = [0, 1, 2, 0, 2, 3]
                point3f[] points = [(-1,-1,0), (1,-1,0), (1,1,0), (-1,1,0)]
                color3f[] primvars:displayColor = [(0.8, 0.2, 0.2)]
            }
        }
    }
}
