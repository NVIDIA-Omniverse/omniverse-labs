#usda 1.0
(
    defaultPrim = "Tree"
    upAxis = "Y"
)

def Xform "Tree"
{
    def Xform "geometry"
    {
        def Mesh "trunk"
        {
            point3f[] points = [(-0.1, 0, 0), (0.1, 0, 0), (0, 1, 0)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
        }

        def Xform "xgBranches" (
            prepend payload = @./native_instance_curve_curves.usda@</Tree/xgBranches>
        )
        {
        }
    }
}
