#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1
    doc = "Correctness test: agibot benchmark scanner SimReady asset. Tests the OmniPBR/MDL loader path including the root-layer reference anchor for ./textures/ resolution."
)

def Xform "World"
{
    def Xform "Asset" (
        prepend references = @agibot_scanner/Aligned.usda@
    )
    {
        # agibot is Z-up; rotate to Y-up
        float xformOp:rotateX = -90
        uniform token[] xformOpOrder = ["xformOp:rotateX"]
    }

    def DomeLight "DomeLight"
    {
        asset inputs:texture:file = @./photo_studio_london_hall_1k.hdr@
        token inputs:texture:format = "latlong"
        float inputs:intensity = 1000
    }

    def Camera "Camera"
    {
        float2 clippingRange = (0.01, 1000)
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 24.0
        token projection = "perspective"
        # eye=(0, 0.25, 1.2), target=(0, 0, 0). Frames the 0.836m tall scanner.
        matrix4d xformOp:transform = ( (1, 0, 0, 0), (0, 0.978980, -0.203954, 0), (0, 0.203954, 0.978980, 0), (0, 0.25, 1.2, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }
}

def "Render"
{
    def "OmniverseKit"
    {
        def "HydraTextures"
        {
            def RenderProduct "ViewportTexture0"
            {
                rel camera = </World/Camera>
                rel orderedVars = </Render/Vars/LdrColor>
                uniform int2 resolution = (640, 480)
                token omni:rtx:rendermode = "RealTimePathTracing"
                token omni:rtx:background:source:type = "domeLight"
                bool omni:rtx:rt:ecoMode:enabled = 0
                int omni:rtx:pt:maxSamplesPerLaunch = 65536
                bool omni:rtx:indirectDiffuse:denoiser:enabled = 0
                bool omni:rtx:reflections:denoiser:enabled = 0
                token[] omni:rtx:waitForEvents = ["AllLoadingFinished", "OnlyOnFirstRequest"]
            }
        }
    }
    def "Vars"
    {
        def RenderVar "LdrColor"
        {
            string sourceName = "LdrColor"
        }
    }
}
