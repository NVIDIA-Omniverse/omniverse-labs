#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
)

def Xform "World"
{
    def PointInstancer "Pawns"
    {
        point3f[] positions = [(0, 0, 0), (3, 0, 0), (6, 0, 0)]
        int[] protoIndices = [0, 0, 0]
        rel prototypes = [
            </World/Pawns/Prototypes/Pawn>,
        ]

        def Scope "Prototypes"
        {
            def Xform "Pawn" (
                prepend references = @./pi_payload_asset.usda@
            )
            {
            }
        }
    }
}
