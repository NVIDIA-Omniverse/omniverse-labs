#usda 1.0
(
    upAxis = "Y"
)

def Xform "World"
{
    def BasisCurves "curve"
    {
        uniform token basis = "bspline"
        uniform token type = "cubic"
        uniform token wrap = "pinned"
        # Note: It's useful to compare with nonperiodic wrap mode where the
        # minimum vertex count is 4. Curves 1,2,3 would be considered invalid,
        # and need to handled gracefully.
        # uniform token wrap = "nonperiodic"
        int[] curveVertexCounts = [5, 3, 2, 1]
        point3f[] points =[
            # curve 0
            (1, 0, 0), (0.70710677, 0.70710677, 0), (-4.371139e-8, 1, 0), (-0.70710677, 0.70710677, 0), (-1, -8.742278e-8, 0),
            # curve 1
            (1, -3, 0), (2, -2, 0), (3, -3, 0),
            # curve 2 (minimum vertex count for pinned curve is 2)
            (1, -6, 0), (2, -6, 0),
            # curve 3 (invalid pinned curve; should be handled gracefully)
            (1, -9, 0)] (
            interpolation = "vertex"
        )
        float[] widths = [
            # curve 0
            0.05, 0.05, 0.05, 0.05, 0.05,
            # curve 1
            0.05, 0.07, 0.05,
            # curve 2
            0.05, 0.07,
            # curve 3
            0.09] (
            interpolation = "vertex"
        )
        color3f[] primvars:displayColor = [
            # curve 0
            (0.7, 0, 0),
            # curve 1
            (0.7, 0.7, 0),
            # curve 2
            (0.7, 0, 0.7),
            # curve 3
            (0, 0.7, 0.7)](
            interpolation = "uniform"
        )
    }

    # --- nanousd-opengl-renderer test additions ---
    # Y-up scene (from header). Curves span X[-1,3] Y[-9,1] Z=0;
    # center ~(1, -4, 0). Camera placed at eye (6, 4, 14) for a 3/4 view
    # along +Z, slightly above the scene; up is +Y.
    def Camera "TestCam"
    {
        float focalLength = 50
        float horizontalAperture = 24
        float verticalAperture = 24
        float2 clippingRange = (0.1, 1000)
        custom matrix4d xformOp:transform = ( (0.941742, 0, -0.336336, 0), (-0.159383, 0.88059, -0.446272, 0), (0.296174, 0.473879, 0.829288, 0), (6, 4, 14, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }

    def DistantLight "Key"
    {
        float inputs:angle = 0.5
        float inputs:intensity = 1500
        # Rotate around X by -45 degrees so the light comes from above-front.
        custom matrix4d xformOp:transform = ( (1, 0, 0, 0), (0, 0.7071068, -0.7071068, 0), (0, 0.7071068, 0.7071068, 0), (0, 0, 0, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }
}
