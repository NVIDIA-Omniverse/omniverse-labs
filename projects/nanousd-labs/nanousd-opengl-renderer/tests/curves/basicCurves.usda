    # --- nanousd-opengl-renderer test additions ---
    # Z-up scene. 7 curve clumps span roughly X[-9,1] Y[-1,1] Z[-2,6];
    # scene center ~(-5, 0, 2). Camera placed for a 3/4 view looking
    # back toward the cluster, eye at (6, -16, 10).
    def Camera "TestCam"
    {
        float focalLength = 50
        float horizontalAperture = 24
        float verticalAperture = 24
        float2 clippingRange = (0.1, 1000)
        custom matrix4d xformOp:transform = ( (0.824042, 0.566529, 0, 0), (-0.215821, 0.313921, 0.924595, 0), (0.52381, -0.761905, 0.380952, 0), (6, -16, 10, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }

    def DistantLight "Key"
    {
        float inputs:angle = 0.5
        float inputs:intensity = 1500
        custom matrix4d xformOp:transform = ( (1, 0, 0, 0), (0, 0.7071068, 0.7071068, 0), (0, -0.7071068, 0.7071068, 0), (0, 0, 0, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }
