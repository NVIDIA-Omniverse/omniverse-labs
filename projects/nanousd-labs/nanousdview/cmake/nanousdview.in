#!/usr/bin/env bash
# Generated by CMake. Launches the Python nanousdview implementation.
set -euo pipefail

SOURCE_DIR="@NANOUSDVIEW_SOURCE_DIR@"
WORKSPACE_DIR="@NANOUSDVIEW_WORKSPACE_DIR@"
if [ -z "${VENV:-}" ]; then
  if [ -d "$WORKSPACE_DIR/.venv312" ]; then
    VENV="$WORKSPACE_DIR/.venv312"
  else
    VENV="$WORKSPACE_DIR/.venv"
  fi
fi

if [ -x "$VENV/bin/python" ]; then
  PYTHON_BIN="$VENV/bin/python"
else
  PYTHON_BIN="${PYTHON:-python3}"
fi

export PYTHONPATH="$SOURCE_DIR/python${PYTHONPATH:+:$PYTHONPATH}"
export PYTHONFAULTHANDLER="${PYTHONFAULTHANDLER:-1}"
exec "$PYTHON_BIN" -m nanousdview "$@"
