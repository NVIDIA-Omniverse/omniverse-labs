{
  "suite": "usdc-spec-parser-basic",
  "contract": "contracts/handles/usdc-spec-parser.handle.json",
  "production_contracts": [
    "contracts/usdc-productions/crate-section-layouts.contract.json",
    "contracts/usdc-productions/crate-reader-diagnostics.contract.json"
  ],
  "spec_commit": "6b4f01f2d6d46b01507481524eb516b4ef358c31",
  "notes": "These cases run the spec parser end-to-end against checked-in .usdc fixtures, comparing against the canonical layer dump shape. The adapter expects the parser to invoke usdc-binary-format for section bytes and usdc-value-decoder for value words, then assemble dumps through usd-document-model into a single growable buffer (no canned literals). Each parse_layer op carries an `opened_resource` object naming the fixture; the harness pre-resolves it through usd_resource_protocol::read_resource(classify_resolved(...)) before invoking the adapter — the adapter never sees a raw fixture path. Dump-emission and parse-strategy compliance are verified by harness/source_audit.py against generated/cpp/usdc_*.cpp, not by self-attestation ops.",
  "cases": [
    {
      "id": "minimal-empty-layer-via-real-decoder",
      "spec_refs": [
        "specification/file_formats/README.md#tokens-section",
        "specification/file_formats/README.md#paths-section",
        "specification/file_formats/README.md#specs-section"
      ],
      "input": {
        "ops": [
          {"op": "parse_layer", "opened_resource": {"ok": true, "fixture": "benchmarks/fixtures/minimal_empty.usdc"}}
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "parse_layer",
            "ok": true,
            "layer": {
              "fields": {"primChildren": {"type": "token[]", "value": []}},
              "specs": {
                "/": {
                  "kind": "layer",
                  "fields": {"primChildren": {"type": "token[]", "value": []}}
                }
              }
            }
          }
        ]
      }
    },
    {
