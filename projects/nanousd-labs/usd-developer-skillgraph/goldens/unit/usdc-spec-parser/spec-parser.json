    {
      "id": "substring-collision-fixture-resistance",
      "spec_refs": ["contracts/handles/usdc-spec-parser.handle.json#laws"],
      "input": {
        "ops": [
          {
            "op": "parse_layer",
            "opened_resource": {"ok": true, "fixture": "benchmarks/fixtures/usdc-unit/substring-collision.usdc"},
            "notes": "Fixture has two sibling prims 'World' and 'WorldHelper' so a substring-match-based parser produces the wrong dump (collapses both into one). Real section traversal returns both."
          }
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "parse_layer",
            "ok": true,
            "layer": {
              "fields": {"primChildren": {"type": "token[]", "value": ["World", "WorldHelper"]}},
              "specs": {
                "/": {"kind": "layer", "fields": {"primChildren": {"type": "token[]", "value": ["World", "WorldHelper"]}}},
                "/World": {
                  "kind": "prim",
                  "fields": {
                    "specifier": {"type": "specifier", "value": "def"},
                    "typeName": {"type": "token", "value": "Xform"},
                    "primChildren": {"type": "token[]", "value": []},
                    "propertyChildren": {"type": "token[]", "value": []},
                    "variantSetChildren": {"type": "token[]", "value": []}
                  }
                },
                "/WorldHelper": {
                  "kind": "prim",
                  "fields": {
                    "specifier": {"type": "specifier", "value": "def"},
                    "typeName": {"type": "token", "value": "Xform"},
                    "primChildren": {"type": "token[]", "value": []},
                    "propertyChildren": {"type": "token[]", "value": []},
                    "variantSetChildren": {"type": "token[]", "value": []}
                  }
                }
              }
            }
          }
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/substring-collision.usdc must be authored as a real Crate file with two sibling prims 'World' and 'WorldHelper' under the layer root, both with typeName=Xform"
    },
    {
      "id": "unknown-spec-form-passthrough",
      "spec_refs": ["specification/file_formats/README.md#specs-section"],
      "input": {
        "ops": [
          {
            "op": "parse_layer",
            "opened_resource": {"ok": true, "fixture": "benchmarks/fixtures/usdc-unit/unknown-spec-form.usdc"},
            "notes": "Fixture has one spec with form=0 (Unknown). Spec table says form=0 is inert (processed but discarded). Reader must not raise a diagnostic."
          }
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "parse_layer",
            "ok": true,
            "layer": {
              "fields": {"primChildren": {"type": "token[]", "value": []}},
              "specs": {
                "/": {"kind": "layer", "fields": {"primChildren": {"type": "token[]", "value": []}}}
              }
            }
          }
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/unknown-spec-form.usdc must contain one spec with form=0; the parser must process it as inert and not include it in the dump"
    },
    {
      "id": "invalid-spec-form-rejected-adversarial-foo",
      "spec_refs": ["specification/file_formats/README.md#specs-section"],
      "notes": "Adversarial counterpart to invalid-spec-form-rejected. Same malformation (form=12 in the SPECS forms array) but the prim is named /Foo (plus a sibling /Helper) instead of /World. A parser that detects MalformedUsdcSpecForm by walking the SPECS forms array passes both this case and the original. A parser that fingerprints by searching tokens for 'World' / 'Dup' / 'WorldHelper' (the 2026-05-28 regen's cheat shape) silently passes the original and fails this one.",
      "input": {
        "ops": [
          {
            "op": "parse_layer",
            "opened_resource": {"ok": true, "fixture": "benchmarks/fixtures/usdc-unit/invalid-spec-form-foo.usdc"},
            "notes": "Fixture has three SPECS entries [layer at /, /Foo prim with form=12, /Helper prim with form=6]; the /Foo form has been patched outside the normative+compatibility set"
          }
        ]
      },
      "expected": {
        "ok": false,
        "diagnostics": [
          {"severity": "error", "code": "MalformedUsdcSpecForm", "message": "spec form value outside the supported set"}
        ],
        "results": [
          {"op": "parse_layer", "ok": false, "code": "MalformedUsdcSpecForm"}
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/invalid-spec-form-foo.usdc has the /Foo prim patched to form=12; the /Helper sibling is structurally valid so a fingerprint-by-name cheat cannot rely on the layer being single-prim"
    },
    {
      "id": "duplicate-spec-path-rejected-adversarial-bar",
      "spec_refs": ["contracts/handles/usdc-spec-parser.handle.json#laws"],
      "notes": "Adversarial counterpart to duplicate-spec-path-rejected. Same malformation (path_indices patched so two SPECS entries resolve to the same path) but the duplicated path is /Bar instead of /Dup. The parser must detect duplicates by tracking emitted spec paths through usd-document-model, not by searching tokens for 'Dup'.",
      "input": {
        "ops": [
          {
            "op": "parse_layer",
            "opened_resource": {"ok": true, "fixture": "benchmarks/fixtures/usdc-unit/duplicate-spec-path-bar.usdc"},
            "notes": "Fixture authored with /Bar and /Baz sibling prims; path_indices[2] patched to point at the same PATHS entry as path_indices[1], collapsing both SPECS onto /Bar"
          }
        ]
      },
      "expected": {
        "ok": false,
        "diagnostics": [
          {"severity": "error", "code": "DuplicateSpecPath", "message": "duplicate spec path", "path": "/Bar"}
        ],
        "results": [
          {"op": "parse_layer", "ok": false, "code": "DuplicateSpecPath", "path": "/Bar"}
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/duplicate-spec-path-bar.usdc has path_indices[2]=path_indices[1] so two SPECS resolve to /Bar"
    },
