    {
      "id": "lz4-buffer-zero-chunk-form",
      "spec_refs": [
        "specification/file_formats/README.md#lz4-compression"
      ],
      "input": {
        "ops": [
          {
            "op": "decode_lz4_buffer",
            "fixture": "benchmarks/fixtures/usdc-unit/lz4-zero-chunk.bin",
            "notes": "chunk_count uint64=0; remainder is one LZ4 stream that decompresses to the canonical reference text 'crate-zero-chunk-roundtrip'"
          }
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "decode_lz4_buffer",
            "ok": true,
            "decompressed_text": "crate-zero-chunk-roundtrip",
            "decompressed_byte_length": 26
          }
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/lz4-zero-chunk.bin must be authored: 8 bytes of zero (chunk_count=0) followed by a single LZ4 stream encoding ASCII 'crate-zero-chunk-roundtrip'"
    },
    {
      "id": "lz4-buffer-multi-chunk-form",
      "spec_refs": [
        "specification/file_formats/README.md#lz4-compression"
      ],
      "input": {
        "ops": [
          {
            "op": "decode_lz4_buffer",
            "fixture": "benchmarks/fixtures/usdc-unit/lz4-multi-chunk.bin",
            "notes": "chunk_count uint64=3; each chunk is prefixed by its 8B compressed size; decompresses to 3*N bytes"
          }
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "decode_lz4_buffer",
            "ok": true,
            "chunk_count_observed": 3,
            "decompressed_text": "chunk-aaaaaaaaaaaaaaaa|chunk-bbbbbbbbbbbbbbbb|chunk-cccccccccccccccc",
            "decompressed_byte_length": 68
          }
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/lz4-multi-chunk.bin must be authored: chunk_count=3, three LZ4-encoded chunks each with their 8B compressed-size prefix"
    },
    {
      "id": "lz4-buffer-corrupt-stream",
      "spec_refs": [
        "specification/file_formats/README.md#lz4-compression"
      ],
      "input": {
        "ops": [
          {
            "op": "decode_lz4_buffer",
            "bytes_hex": "0000000000000000ffffffffffffffff",
            "notes": "chunk_count=0; remainder is 8 bytes of 0xFF which is not a valid LZ4 stream"
          }
        ]
      },
      "expected": {
        "ok": false,
        "diagnostics": [
          {
            "severity": "error",
            "code": "MalformedUsdcLz4Buffer",
            "message": "LZ4 stream is corrupt"
          }
        ],
        "results": [
          {
            "op": "decode_lz4_buffer",
            "ok": false,
            "code": "MalformedUsdcLz4Buffer"
          }
        ]
      }
    },
