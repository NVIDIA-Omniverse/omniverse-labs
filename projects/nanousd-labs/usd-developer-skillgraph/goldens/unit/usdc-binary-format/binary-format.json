    {
      "id": "compressed-int-array-uint-signed-common",
      "spec_refs": [
        "specification/file_formats/README.md#compressed-integer-arrays"
      ],
      "notes": "decoding common value as unsigned would yield 0xFFFFFFFD instead of -3 and corrupt the running sum [Moved from expected.results[].notes — score.py treats expected as a deep-comparison target, so prose here would force the adapter to emit the literal. Case-level notes are documentation only.]",
      "input": {
        "ops": [
          {
            "op": "decode_compressed_int_array",
            "fixture": "benchmarks/fixtures/usdc-unit/compuint32-signed-common.bin",
            "elementType": "uint32",
            "elementCount": 5,
            "notes": "the array element type is unsigned but the common value is the negative delta -3; readers must store common as signed int32"
          }
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "decode_compressed_int_array",
            "ok": true,
            "elementType": "uint32",
            "values": [
              100,
              97,
              94,
              91,
              88
            ]
          }
        ]
      },
      "fixture_obligation": "benchmarks/fixtures/usdc-unit/compuint32-signed-common.bin must encode a 5-element uint32 array with all codepoints == 00 and a common value of -3 (stored as signed int32 0xFFFFFFFD)"
    },
