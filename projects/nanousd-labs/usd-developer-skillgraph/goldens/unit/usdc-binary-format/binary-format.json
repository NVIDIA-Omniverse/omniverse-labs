    {
      "id": "real-minimal-fixture-read-toc",
      "spec_refs": [
        "specification/file_formats/README.md#table-of-contents",
        "specification/file_formats/README.md#tokens-section",
        "specification/file_formats/README.md#paths-section"
      ],
      "notes": "exact offset/size values vary per fixture; goldens match section_kinds presence and count, not byte coordinates [Moved from expected.results[].notes — score.py treats expected as a deep-comparison target, so prose here would force the adapter to emit the literal. Case-level notes are documentation only.]",
      "input": {
        "ops": [
          {
            "op": "validate_header",
            "fixture": "benchmarks/fixtures/minimal_empty.usdc"
          },
          {
            "op": "read_toc",
            "fixture": "benchmarks/fixtures/minimal_empty.usdc"
          },
          {
            "op": "section_kinds_present",
            "fixture": "benchmarks/fixtures/minimal_empty.usdc"
          }
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {
            "op": "validate_header",
            "ok": true,
            "version": {
              "major": 0,
              "minor": 8,
              "patch": 0
            },
            "tocOffset": 328
          },
          {
            "op": "read_toc",
            "ok": true,
            "section_count": 6,
            "section_kinds": [
              "TOKENS",
              "STRINGS",
              "FIELDS",
              "FIELDSETS",
              "PATHS",
              "SPECS"
            ]
          },
          {
            "op": "section_kinds_present",
            "ok": true,
            "TOKENS": true,
            "STRINGS": true,
            "FIELDS": true,
            "FIELDSETS": true,
            "PATHS": true,
            "SPECS": true
          }
        ]
      }
    },
