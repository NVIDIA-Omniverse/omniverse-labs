      "id": "typed-attribute-reader-mapping",
      "input": {
        "ops": [
          {"op": "describe_attribute_reader", "function": "nanousd_attribf", "storedType": "half", "payloadKind": "scalar"},
          {"op": "describe_attribute_reader", "function": "nanousd_attribv3f", "storedType": "point3f", "payloadKind": "semanticAlias"},
          {"op": "describe_attribute_reader", "function": "nanousd_attribqf", "storedType": "quatf", "payloadKind": "quaternion"},
