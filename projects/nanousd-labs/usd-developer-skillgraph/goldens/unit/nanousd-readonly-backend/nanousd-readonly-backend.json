            "jsonPolicy": "malloc_string_freed_by_nanousd_free_string",
            "severityPolicy": "recoverable composition diagnostics reported as errors until warning taxonomy is contracted",
            "relocateArcType": 8,
            "invalidRelocateCategory": 8
          },
          {"op": "describe_vtable_slot", "ok": true, "function": "nanousd_open", "slot": "open", "nonnull": true, "support": "readonly", "pointerPolicy": "generated_readonly_implementation"},
          {"op": "describe_vtable_slot", "ok": true, "function": "nanousd_attribqf", "slot": "attribqf", "nonnull": true, "support": "readonly", "pointerPolicy": "generated_readonly_implementation"},
