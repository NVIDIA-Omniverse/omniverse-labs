          {"op": "classify_function", "ok": true, "name": "nanousd_attribqf", "category": "attribute", "support": "readonly", "reason": "reads quaternion field payloads with USD-to-C-API component order conversion"},
          {"op": "classify_function", "ok": true, "name": "nanousd_attribm4d", "category": "attribute", "support": "readonly", "reason": "reads matrix4d field payloads as row-major double[16]"},
          {"op": "classify_function", "ok": true, "name": "nanousd_attribarrayv3f", "category": "attribute", "support": "readonly", "reason": "copies homogeneous vec3-compatible array payloads into caller storage"},
          {"op": "classify_function", "ok": true, "name": "nanousd_samplev3f", "category": "timeSamples", "support": "readonly", "reason": "reads exact authored time sample keys from native TimeSamples values"},
          {"op": "classify_function", "ok": true, "name": "nanousd_reltarget", "category": "relationships", "support": "readonly", "reason": "reads relationship target listOp/ObjectPath field payloads"},
          {"op": "classify_function", "ok": true, "name": "nanousd_path_parse", "category": "path", "support": "utility", "reason": "delegates to usd-paths handle semantics"},
          {"op": "classify_function", "ok": true, "name": "nanousd_set_attribf", "category": "write", "support": "unsupported_stub", "reason": "read-only backend does not mutate attributes"},
          {"op": "classify_function", "ok": true, "name": "nanousd_write_usdc", "category": "write", "support": "unsupported_stub", "reason": "read-only backend does not serialize layer files"}
        ]
      }
