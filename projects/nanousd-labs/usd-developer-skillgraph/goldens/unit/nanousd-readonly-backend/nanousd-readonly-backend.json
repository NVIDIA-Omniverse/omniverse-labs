          {"op": "describe_attribute_reader", "function": "nanousd_attribm4d", "storedType": "frame4d", "payloadKind": "semanticAlias"},
          {"op": "describe_attribute_reader", "function": "nanousd_attribarrayv3f", "storedType": "point3f[]", "payloadKind": "array"},
          {"op": "describe_attribute_reader", "function": "nanousd_arraydataf", "storedType": "float[]", "payloadKind": "array"},
          {"op": "describe_attribute_reader", "function": "nanousd_attribv3f", "storedType": "double3", "payloadKind": "dimensioned"}
        ]
      },
      "expected": {
        "ok": true,
        "diagnostics": [],
        "results": [
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "half", "cOutput": "float", "conversion": "half payload converts to float at C API boundary"},
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "float3", "cOutput": "float[3]", "conversion": "semantic alias point3f agrees with float3"},
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "quatf", "cOutput": "float[4]", "conversion": "reorder USD i,j,k,w payload to nanousd w,i,j,k output"},
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "quatd", "cOutput": "double[4]", "conversion": "reorder USD i,j,k,w payload to nanousd w,i,j,k output"},
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "matrix3d", "cOutput": "double[9]", "conversion": "flatten row-major matrix payload"},
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "matrix4d", "cOutput": "double[16]", "conversion": "semantic alias frame4d agrees with matrix4d and flattens row-major"},
          {"op": "describe_attribute_reader", "ok": true, "supported": true, "checkedReadType": "float3[]", "cOutput": "flat float[3 * count]", "conversion": "semantic alias array point3f[] agrees with float3[]"},
          {"op": "describe_attribute_reader", "ok": true, "supported": false, "checkedReadType": "float[]", "cOutput": "const float* plus count", "conversion": "zero-copy arraydata is optional until contiguous storage is contracted"},
          {"op": "describe_attribute_reader", "ok": true, "supported": false, "checkedReadType": "float3", "cOutput": "float[3]", "conversion": "stored double3 does not agree with requested float3 reader"}
